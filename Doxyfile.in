PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "Decrypt DBeaver credentials-config.json."
OUTPUT_DIRECTORY       = "@CMAKE_BINARY_DIR@"
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
INPUT                  = "@CMAKE_SOURCE_DIR@/include"
FILE_PATTERNS          = *.h
RECURSIVE              = YES
QUIET                  = YES
WARN_AS_ERROR          = YES
EXTRACT_ALL            = YES
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
HAVE_DOT               = NO
